# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ArogyaX

# ── API Routing ───────────────────────────────────────────────────────────────
# The URL of your Backend (e.g., https://arogyax-backend.onrender.com)
# This is used by the Next.js server to proxy requests to FastAPI.
INTERNAL_BACKEND_URL=http://localhost:8000

# ── Auth & Cookies ───────────────────────────────────────────────────────────
# Must match the Backend's AUTH_COOKIE_NAME
NEXT_PUBLIC_AUTH_COOKIE_NAME=auth-token
