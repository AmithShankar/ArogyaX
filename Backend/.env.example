# ── Admin ─────────────────────────────────────────────────────────────────────
# Initial Admin Credentials (used by seed_admin.py)
INITIAL_ADMIN_PHONE=1234567890
INITIAL_ADMIN_PASSWORD=Admin@123

# ── Database ──────────────────────────────────────────────────────────────────
# Sync URL (used by Alembic migrations)
DATABASE_URL=postgresql+psycopg2://postgres:DB_PASS@DB_HOST:5432/postgres?sslmode=require
# Async URL (used at runtime)
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:DB_PASS@DB_HOST:5432/postgres?sslmode=require
# Required for Supabase/Cloud DBs
DB_SSL_MODE=require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Auth & Cookies ───────────────────────────────────────────────────────────
AUTH_COOKIE_NAME=auth-token
# Set to 'strict' or 'lax'
AUTH_COOKIE_SAMESITE=strict

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=True
# Leave empty for local memory storage, or use redis://host:port
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_GLOBAL_IP_LIMITS=300/minute

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads

# ── Environment ───────────────────────────────────────────────────────────────
# Set to True in production to enable secure cookies and HSTS
IS_PRODUCTION=False
# Enable if running behind a proxy (Vercel/Render)
USE_PROXY_HEADERS=False
